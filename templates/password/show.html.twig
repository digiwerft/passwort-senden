{% extends 'base.html.twig' %}

{% block title %}Passwort anzeigen – Cyber-Securitas{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">

        {% if valid %}

            {# Error from wrong link password etc. #}
            {% for message in app.flashes('reveal_error') %}
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <div class="card">
                <div class="card-body text-center py-5">

                    <div class="icon-circle icon-circle-danger mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                        </svg>
                    </div>

                    <h4 class="mb-2">Verschlüsseltes Passwort</h4>
                    <p class="text-muted mb-4">
                        Das Passwort wird nur <strong>einmalig</strong> angezeigt und ist danach nicht mehr aufrufbar.
                    </p>

                    <form method="post" action="/show">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('show_password') }}">
                        <input type="hidden" name="secretKey" value="{{ secretKey }}">

                        {% if requiresPassword %}
                            <div class="mb-4 text-start">
                                <label for="link_password" class="form-label">Linkpasswort</label>
                                <input
                                    type="password"
                                    class="form-control"
                                    id="link_password"
                                    name="link_password"
                                    placeholder="Linkpasswort eingeben"
                                    required
                                    autofocus
                                >
                                <div class="form-text">Dieser Link ist durch ein Passwort geschützt.</div>
                            </div>
                        {% endif %}

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                                    <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/>
                                    <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>
                                </svg>
                                Passwort anzeigen
                            </button>
                        </div>
                    </form>

                    <p class="text-muted small mt-4 mb-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                            <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                        </svg>
                        Nach dem Anzeigen wird das Passwort unwiderruflich gelöscht.
                    </p>
                </div>
            </div>

        {% else %}

            <div class="card">
                <div class="card-body text-center py-5">
                    <div class="icon-circle icon-circle-warning mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                        </svg>
                    </div>
                    <h4 class="mb-2">Link ungültig oder abgelaufen</h4>
                    <p class="text-muted mb-4">
                        Dieser Link existiert nicht mehr. Er wurde möglicherweise bereits geöffnet oder ist abgelaufen.
                    </p>
                    <a href="/" class="btn btn-danger">Neuen Link erstellen</a>
                </div>
            </div>

        {% endif %}

    </div>
</div>
{% endblock %}
