<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Cyber-Securitas{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <style>
        :root {
            --cs-primary: #dc3545;
            --cs-dark:    #1a1a2e;
        }

        body {
            background-color: #f5f6fa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        /* Navbar */
        .navbar {
            background: #ffffff;
            box-shadow: 0 1px 4px rgba(0,0,0,.08);
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.3rem;
            color: var(--cs-dark) !important;
            letter-spacing: -.3px;
        }

        .navbar-brand span {
            color: var(--cs-primary);
        }

        /* Main content area */
        main {
            flex: 1;
            padding: 3rem 0;
        }

        /* Cards */
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 16px rgba(0,0,0,.07);
        }

        .card-header {
            background: transparent;
            border-bottom: 1px solid rgba(0,0,0,.06);
            padding: 1.25rem 1.5rem;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .card-body {
            padding: 1.75rem 1.5rem;
        }

        /* Buttons */
        .btn-danger {
            background-color: var(--cs-primary);
            border-color: var(--cs-primary);
        }

        /* Form labels */
        .form-label {
            font-weight: 500;
            color: #444;
            margin-bottom: .35rem;
        }

        .form-control, .form-select {
            border-radius: 8px;
            border-color: #dee2e6;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--cs-primary);
            box-shadow: 0 0 0 .2rem rgba(220,53,69,.15);
        }

        /* Info badge / alert */
        .alert {
            border-radius: 10px;
            border: none;
        }

        /* Link display */
        .link-display {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            padding: .75rem 1rem;
            font-family: monospace;
            font-size: .85rem;
            word-break: break-all;
            color: #333;
        }

        /* Footer */
        footer {
            background: #ffffff;
            border-top: 1px solid #e9ecef;
            padding: 1.1rem 0;
            color: #888;
            font-size: .85rem;
            text-align: center;
        }

        footer a { color: #888; text-decoration: underline; }
        footer a:hover { color: #666; }

        /* Lock icon circle */
        .icon-circle {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin: 0 auto 1rem;
        }

        .icon-circle-danger  { background: rgba(220,53,69,.1);  color: var(--cs-primary); }
        .icon-circle-success { background: rgba(25,135,84,.1);  color: #198754; }
        .icon-circle-warning { background: rgba(255,193,7,.15); color: #856404; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="/">Cyber<span>-Securitas</span></a>
    </div>
</nav>

<main>
    <div class="container">
        {% block body %}{% endblock %}
    </div>
</main>

<footer>
    <div class="container">
        &copy; DIGIWERFT GmbH &nbsp;|&nbsp; <a href="https://www.digiwerft.de/impressum.html" target="_blank" rel="noopener noreferrer">Impressum</a> &nbsp;|&nbsp; <a href="https://www.digiwerft.de/datenschutz.html" target="_blank" rel="noopener noreferrer">Datenschutz</a>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
